@* Region content for the users-list shell; OOB updates are appended separately. *@
<h3>Latest Created User</h3>
<p>
    <strong>@DisplayName</strong> was created.
</p>
<p>Total users: @Count</p>

@code {
    [Parameter]
    public string DisplayName { get; set; } = string.Empty;

    [Parameter]
    public int Count { get; set; }
}
