@* Demonstrates first-party head queue/flush support on HTMX partial responses. *@
<section class="panel">
    <h2>Head Handling</h2>
    <p>Queues document <code>&lt;title&gt;</code>, <code>&lt;meta&gt;</code>, <code>&lt;style&gt;</code>, and <code>&lt;script&gt;</code> updates from the server.</p>
</section>

<section id="head-demo" class="panel">
    <h3>Head Queue + Flush</h3>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> submit this form, then submit it again with a different accent.
        The tab title should change, the preview chip should restyle, and the script load count should stay at <code>1</code>.
    </div>
    <p class="demo-caption">
        Expected outcome: inspector shows the request/response cycle, the tab title changes immediately,
        and repeated submits replace keyed head items instead of duplicating them.
    </p>

    <form
        id="head-demo-form"
        action="/fragments/head/update"
        hx-post="/fragments/head/update"
        hx-target="#head-demo-result"
        hx-swap="outerHTML"
        hx-ext="head-support"
        hx-indicator="#head-indicator"
        hx-disabled-elt="find button">
        <HrzAntiforgeryInput />

        <label for="head-title-input">Title</label>
        <input id="head-title-input" name="title" value="HyperRazor • Head Demo" />

        <label for="head-description-input">Description</label>
        <input id="head-description-input" name="description" value="Updated via HrzHeadService + head-support." />

        <label for="head-accent-input">Accent</label>
        <select id="head-accent-input" name="accent">
            <option value="teal" selected>Teal</option>
            <option value="amber">Amber</option>
            <option value="rose">Rose</option>
        </select>

        <button type="submit">Queue Head Update</button>
        <span id="head-indicator" class="hrz-indicator" aria-live="polite">Updating head…</span>
    </form>

    <section id="head-demo-result" class="panel">
        <h3>Awaiting update</h3>
        <p>Submit the form to queue a keyed head update from the server.</p>
    </section>
</section>
