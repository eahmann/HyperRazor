@inject HtmxConfig HtmxConfig
@inherits LayoutComponentBase

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" hx-preserve="true" />
    <meta name="viewport" content="width=device-width, initial-scale=1" hx-preserve="true" />
    <title>HyperRazor</title>
    <HrzHtmxConfigMeta />
    <HrzAntiforgeryMeta />
    <script src="/_content/HyperRazor.Components/vendor/htmx/htmx-2.0.4.min.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Components/vendor/htmx/head-support-2.0.2.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Components/vendor/aspnet-client-validation/aspnet-validation.min.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Components/vendor/htmx/sse-2.2.4.min.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Components/hyperrazor.htmx.js" defer hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Components/hyperrazor.validation.js" defer hx-preserve="true"></script>
    <link rel="stylesheet" href="/_content/HyperRazor.Components/hyperrazor.css" hx-preserve="true" />
</head>
<body
    data-hrz-antiforgery-meta="@HtmxConfig.AntiforgeryMetaName"
    data-hrz-antiforgery-header="@HtmxConfig.AntiforgeryHeaderName"
    data-hrz-head-support="@(HtmxConfig.EnableHeadSupport ? "true" : "false")"
    hx-ext="@(HtmxConfig.EnableHeadSupport ? "head-support" : null)">
    <div id="hrz-app-shell">
        @Body
    </div>
</body>
</html>
