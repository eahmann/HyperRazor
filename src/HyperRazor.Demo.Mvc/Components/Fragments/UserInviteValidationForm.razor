@using HyperRazor.Demo.Mvc.Models
@using HyperRazor.Rendering
@using Microsoft.AspNetCore.Http
@using System.Text.Json

<section
    id="@FormShellId"
    class="panel validation-form-shell"
    data-hrz-validation-root="@Form.RootId.Value"
    data-hrz-validation-region>
    <h3>@Form.PanelTitle</h3>
    <p class="empty">@Form.PanelDescription</p>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> @Form.Instructions
    </div>

    @if (Form.Success)
    {
        <p class="validation-success">
            @Form.SuccessVerb <strong>@Form.Input.DisplayName</strong> (<code>@Form.Input.Email</code>) as user #@Form.Count.
        </p>
    }

    <HrzForm
        Model="Form.Input"
        Action="@Form.Action"
        FormName="@Form.RootId.Value"
        AdditionalAttributes="@FormAttributes">
        <HrzValidationSummary />

        <div class="validation-field @(HrzFormRendering.HasErrors(ValidationState, DisplayNamePath) ? "validation-field--invalid" : null)">
            <HrzField For="() => Form.Input.DisplayName">
                <HrzLabel Text="Display Name" />
                <HrzInput AdditionalAttributes="@DisplayNameInputAttributes" />
                <HrzValidationMessage />
            </HrzField>
        </div>

        <div class="validation-field @(HrzFormRendering.HasErrors(ValidationState, EmailPath) ? "validation-field--invalid" : null)">
            <HrzField For="() => Form.Input.Email">
                <HrzLabel Text="Email" />
                <HrzInput Type="email" AdditionalAttributes="@EmailInputAttributes" />
                <HrzValidationMessage />
            </HrzField>
        </div>

        <button type="submit">@Form.ButtonText</button>
    </HrzForm>
</section>

@code {
    public static HrzValidationRootId RootId { get; } = UserInviteValidationRoots.MvcLocal;
    public static HrzFieldPath DisplayNamePath { get; } = HrzFieldPaths.FromFieldName(nameof(InviteUserInput.DisplayName));
    public static HrzFieldPath EmailPath { get; } = HrzFieldPaths.FromFieldName(nameof(InviteUserInput.Email));

    [Inject]
    private IHrzHtmlIdGenerator HtmlIdGenerator { get; set; } = default!;

    [Parameter]
    public InviteValidationFormViewModel Form { get; set; } = UserInviteValidationDefinitions.MvcLocal();

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private HrzSubmitValidationState? ValidationState =>
        HttpContext?.GetSubmitValidationState(Form.RootId);

    private string ResolvedHxPost => string.IsNullOrWhiteSpace(Form.HxPost) ? Form.Action : Form.HxPost;
    private bool EnableClientValidation => Form.EnableClientValidation;
    private bool HasLiveValidation => !string.IsNullOrWhiteSpace(Form.LiveValidationPath);
    private string? DisplayNameLiveValidationPath => HasLiveValidation ? Form.LiveValidationPath : null;
    private string? EmailLiveValidationPath => HasLiveValidation ? Form.LiveValidationPath : null;
    private string? LiveValidationTrigger => HasLiveValidation ? "input changed delay:400ms, blur" : null;
    private string? DisplayNameLiveValidationTarget => HasLiveValidation ? $"#{DisplayNameServerSlotId}" : null;
    private string? EmailLiveValidationTarget => HasLiveValidation ? $"#{EmailServerSlotId}" : null;
    private string? LiveValidationSwap => HasLiveValidation ? "outerHTML" : null;
    private string? LiveValidationInclude => HasLiveValidation ? "closest form" : null;
    private string? DisplayNameLiveValidationValuesJson => BuildLiveValidationValuesJson(DisplayNamePath);
    private string? EmailLiveValidationValuesJson => BuildLiveValidationValuesJson(EmailPath);
    private string FormShellId => $"{Form.IdPrefix}-form-shell";
    private string FormId => $"{Form.IdPrefix}-form";
    private string SummaryId => HtmlIdGenerator.GetSummaryId(Form.RootId.Value);
    private string DisplayNameMessageId => HtmlIdGenerator.GetFieldMessageId(Form.RootId.Value, DisplayNamePath);
    private string DisplayNameClientSlotId => $"{DisplayNameMessageId}--client";
    private string DisplayNameServerSlotId => $"{DisplayNameMessageId}--server";
    private string EmailMessageId => HtmlIdGenerator.GetFieldMessageId(Form.RootId.Value, EmailPath);
    private string EmailClientSlotId => $"{EmailMessageId}--client";
    private string EmailServerSlotId => $"{EmailMessageId}--server";

    private IReadOnlyDictionary<string, object?> FormAttributes => new Dictionary<string, object?>
    {
        ["id"] = FormId,
        ["class"] = "validation-form",
        ["hx-post"] = ResolvedHxPost,
        ["hx-target"] = $"#{FormShellId}",
        ["hx-swap"] = "outerHTML focus-scroll:true",
        ["hx-disabled-elt"] = "find button",
        ["novalidate"] = "novalidate"
    };

    private IReadOnlyDictionary<string, object?> DisplayNameInputAttributes => new Dictionary<string, object?>
    {
        ["data-hrz-local-display-name"] = EnableClientValidation ? "true" : null,
        ["data-hrz-client-slot-id"] = EnableClientValidation ? DisplayNameClientSlotId : null,
        ["data-hrz-server-slot-id"] = HasLiveValidation ? DisplayNameServerSlotId : null,
        ["data-hrz-summary-slot-id"] = HasLiveValidation ? SummaryId : null,
        ["hx-post"] = DisplayNameLiveValidationPath,
        ["hx-trigger"] = LiveValidationTrigger,
        ["hx-target"] = DisplayNameLiveValidationTarget,
        ["hx-swap"] = LiveValidationSwap,
        ["hx-include"] = LiveValidationInclude,
        ["hx-vals"] = DisplayNameLiveValidationValuesJson
    };

    private IReadOnlyDictionary<string, object?> EmailInputAttributes => new Dictionary<string, object?>
    {
        ["data-hrz-local-email"] = EnableClientValidation ? "true" : null,
        ["data-hrz-client-slot-id"] = EnableClientValidation ? EmailClientSlotId : null,
        ["data-hrz-server-slot-id"] = HasLiveValidation ? EmailServerSlotId : null,
        ["data-hrz-summary-slot-id"] = HasLiveValidation ? SummaryId : null,
        ["data-hrz-dependent-server-slot-ids"] = HasLiveValidation ? DisplayNameServerSlotId : null,
        ["hx-post"] = EmailLiveValidationPath,
        ["hx-trigger"] = LiveValidationTrigger,
        ["hx-target"] = EmailLiveValidationTarget,
        ["hx-swap"] = LiveValidationSwap,
        ["hx-include"] = LiveValidationInclude,
        ["hx-vals"] = EmailLiveValidationValuesJson
    };

    private string? BuildLiveValidationValuesJson(HrzFieldPath fieldPath)
    {
        return HasLiveValidation
            ? JsonSerializer.Serialize(new Dictionary<string, string>
            {
                ["__hrz_root"] = Form.RootId.Value,
                ["__hrz_fields"] = fieldPath.Value
            })
            : null;
    }
}
