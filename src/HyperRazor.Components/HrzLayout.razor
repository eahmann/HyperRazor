@typeparam TLayout where TLayout : IComponent

@if (IsHtmxRequest)
{
    <HrzMinimalLayout>
        @ChildContent
    </HrzMinimalLayout>
}
else
{
    <LayoutView Layout="typeof(TLayout)">
        @ChildContent
    </LayoutView>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool IsHtmxRequest { get; set; }
}
