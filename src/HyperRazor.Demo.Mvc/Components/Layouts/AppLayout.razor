@inject HtmxConfig HtmxConfig
@inherits LayoutComponentBase

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" hx-preserve="true" />
    <meta name="viewport" content="width=device-width, initial-scale=1" hx-preserve="true" />
    <title>HyperRazor</title>
    <HrzHtmxConfigMeta />
    <HrzAntiforgeryMeta />
    <script src="/_content/HyperRazor.Client/vendor/htmx/htmx-2.0.4.min.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Client/vendor/htmx/head-support-2.0.2.js" hx-preserve="true"></script>
    <script src="/_content/HyperRazor.Client/hyperrazor.htmx.js" defer hx-preserve="true"></script>
    <link rel="stylesheet" href="/_content/HyperRazor.Client/hyperrazor.css" hx-preserve="true" />
    <link rel="stylesheet" href="/app.css" hx-preserve="true" />
</head>
<body
    data-hrz-antiforgery-meta="@HtmxConfig.AntiforgeryMetaName"
    data-hrz-antiforgery-header="@HtmxConfig.AntiforgeryHeaderName"
    data-hrz-head-support="@(HtmxConfig.EnableHeadSupport ? "true" : "false")"
    hx-ext="@(HtmxConfig.EnableHeadSupport ? "head-support" : null)">
    <div id="hrz-app-shell" data-hrz-layout-family="@CurrentLayoutFamily">
        <header id="app-shell">
            <div class="app-title-row">
                <p class="app-kicker">HTMX + SSR Playground</p>
                <h1>HyperRazor</h1>
                <p class="app-tagline">
                    Focused, inspectable examples that show how server-driven UI updates behave in real requests.
                </p>
            </div>
            <div class="app-header-nav-region">
                <SectionOutlet SectionName="AppHeaderNav" />
            </div>
        </header>

        <main id="hrz-main-layout" class="layout">
            @Body
        </main>
    </div>

    <section id="hrz-inspector-shell" class="panel panel--inspector">
        <div id="hx-debug-shell">
            <h3>HX Request/Response Inspector</h3>
            <p class="empty">Run HTMX actions to inspect the latest request and response headers.</p>
            <div class="demo-note" role="note">
                <strong>Inspector Note:</strong> this region is updated out-of-band after each HTMX interaction,
                so you can inspect both inbound and outbound HX headers in one place.
            </div>
        </div>
    </section>
</body>
</html>

@code {
    [CascadingParameter]
    public HrzShellContext? ShellContext { get; set; }

    private string CurrentLayoutFamily => string.IsNullOrWhiteSpace(ShellContext?.LayoutFamily)
        ? "main"
        : ShellContext.LayoutFamily;
}
