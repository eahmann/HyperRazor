<label for="@ResolvedField.InputId" class="@Class" @attributes="AdditionalAttributes">
    @(string.IsNullOrWhiteSpace(Text) ? ResolvedField.LabelText : Text)
</label>

@code {
    [Parameter]
    public string? Text { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HrzFieldScope? Field { get; set; }

    private HrzFieldScope ResolvedField => Field
        ?? throw new InvalidOperationException($"{nameof(HrzLabel)} requires a cascading {nameof(HrzField<object>)}.");

    protected override void OnParametersSet()
    {
        _ = ResolvedField;
    }
}
