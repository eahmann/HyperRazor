@typeparam TModel
@using Microsoft.AspNetCore.Http

<CascadingValue Value="_formScope">
    <form
        id="@_formScope.FormId"
        class="@Class"
        action="@Action"
        data-hrz-validation-root="@_formScope.RootId.Value"
        data-hrz-validation-region
        data-hrz-disabled-elt="@(Enhance ? DisabledElementSelector : null)"
        hx-post="@(Enhance ? ResolvedHxPost : null)"
        hx-target="@(Enhance ? SubmitTarget : null)"
        hx-swap="@(Enhance ? SubmitSwap : null)"
        novalidate
        @attributes="AdditionalAttributes">
        <HrzAntiforgeryInput />
        @ChildContent
        <HrzLivePolicyRegion />
    </form>
</CascadingValue>

@code {
    [Parameter, EditorRequired]
    public TModel Model { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Action { get; set; } = string.Empty;

    [Parameter]
    public string? FormName { get; set; }

    [Parameter]
    public HrzValidationRootId? RootId { get; set; }

    [Parameter]
    public string? IdPrefix { get; set; }

    [Parameter]
    public string HxPost { get; set; } = string.Empty;

    [Parameter]
    public string? SubmitTarget { get; set; }

    [Parameter]
    public string SubmitSwap { get; set; } = "outerHTML focus-scroll:true";

    [Parameter]
    public string DisabledElementSelector { get; set; } = "find button";

    [Parameter]
    public bool Enhance { get; set; } = true;

    [Parameter]
    public bool EnableClientValidation { get; set; } = true;

    [Parameter]
    public HrzLiveValidationOptions? Live { get; set; }

    [Parameter]
    public string? LiveValidationPath { get; set; }

    [Parameter]
    public string LiveTrigger { get; set; } = "input changed delay:400ms, blur";

    [Parameter]
    public string LiveInclude { get; set; } = "closest form";

    [Parameter]
    public string LiveSync { get; set; } = "closest form:abort";

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    [Inject]
    private IHrzForms HrzForms { get; set; } = default!;

    private HrzFormScope<TModel> _formScope = default!;

    private string ResolvedHxPost => string.IsNullOrWhiteSpace(HxPost) ? Action : HxPost;

    protected override void OnParametersSet()
    {
        ArgumentNullException.ThrowIfNull(Model);
        ArgumentException.ThrowIfNullOrWhiteSpace(Action);

        var address = HrzValidationFormAddress.CreateRequired(
            RootId,
            FormName,
            $"{nameof(HrzForm<object>)}");
        _formScope = string.IsNullOrWhiteSpace(IdPrefix)
            ? HrzForms.For(Model!, address, live: ResolveLiveOptions(), enableClientValidation: EnableClientValidation)
            : HrzForms.For(Model!, address, live: ResolveLiveOptions(), idPrefix: IdPrefix, enableClientValidation: EnableClientValidation);
    }

    private HrzLiveValidationOptions? ResolveLiveOptions()
    {
        var legacyPath = string.IsNullOrWhiteSpace(LiveValidationPath) ? null : LiveValidationPath;
        if (Live is null && legacyPath is null)
        {
            return null;
        }

        return new HrzLiveValidationOptions
        {
            Path = !string.IsNullOrWhiteSpace(Live?.Path) ? Live.Path : legacyPath,
            Trigger = Live?.Trigger ?? LiveTrigger,
            Include = Live?.Include ?? LiveInclude,
            Sync = Live?.Sync ?? LiveSync
        };
    }
}
