@if (HasContainer)
{
    <div class="@Class" @attributes="AdditionalAttributes">
        @Slots
    </div>
}
else
{
    @Slots
}

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HrzFieldScope? Field { get; set; }

    private HrzFieldScope ResolvedField => Field
        ?? throw new InvalidOperationException($"{nameof(HrzValidationMessage)} requires a cascading {nameof(HrzField<object>)}.");

    private bool HasContainer => !string.IsNullOrWhiteSpace(Class) || (AdditionalAttributes?.Count ?? 0) > 0;

    private RenderFragment Slots => @<text>
        <div
            id="@ResolvedField.ClientSlotId"
            class="validation-slot validation-slot--client field-validation-valid"
            data-hrz-client-validation-for="@ResolvedField.FieldPath.Value"
            data-valmsg-for="@ResolvedField.Name"
            data-valmsg-replace="true"></div>

        <HrzValidationServerFieldSlot
            Id="@ResolvedField.ServerSlotId"
            FieldPath="@ResolvedField.FieldPath.Value"
            Errors="@ResolvedField.Errors" />
    </text>;

    protected override void OnParametersSet()
    {
        _ = ResolvedField;
    }
}
