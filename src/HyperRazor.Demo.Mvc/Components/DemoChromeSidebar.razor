<div class="sidebar-shell sticky-shell">
<section class="app-sidebar-card">
    <div class="sidebar-heading-block">
        <p class="sidebar-kicker">Operations</p>
        <h2>Navigation</h2>
        <p class="sidebar-caption">Server-owned chrome. Boosted page requests keep this rail aligned through OOB swaps.</p>
    </div>

    <div class="sidebar-mode-block" role="status" aria-live="polite">
        <span class="sidebar-mode-label">Active shell</span>
        <span class="sidebar-mode-value">@LayoutFamily</span>
    </div>

    <DemoNavLinks ActiveSection="@ActiveSection" />
</section>
</div>

@code {
    [Parameter]
    public string ActiveSection { get; set; } = "/";

    [Parameter]
    public string LayoutFamily { get; set; } = "admin";
}
