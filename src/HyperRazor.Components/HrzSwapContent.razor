@implements IDisposable
@inject IHrzSwapBuffer SwapBuffer

@if (SwapBuffer.ContentAvailable)
{
    @SwapBuffer.RenderToFragment(clear: true)
}

@code {
    protected override void OnInitialized()
    {
        SwapBuffer.ContentItemsUpdated += OnContentItemsUpdated;
    }

    public void Dispose()
    {
        SwapBuffer.ContentItemsUpdated -= OnContentItemsUpdated;
    }

    private void OnContentItemsUpdated(object? sender, EventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
