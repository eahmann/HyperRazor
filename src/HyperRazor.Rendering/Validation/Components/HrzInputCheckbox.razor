@namespace HyperRazor.Components
@inherits HrzValidationInputComponentBase

<input checked="@ResolvedFieldContext.IsChecked" @attributes="InputAttributes" />

@if (IncludeHiddenInput)
{
    <input type="hidden" name="@ResolvedFieldContext.Name" value="false" />
}

@code {
    [Parameter]
    public bool IncludeHiddenInput { get; set; } = true;

    private IReadOnlyDictionary<string, object> InputAttributes => BuildControlAttributes(new Dictionary<string, object?>
    {
        ["type"] = "checkbox",
        ["value"] = "true"
    });
}
