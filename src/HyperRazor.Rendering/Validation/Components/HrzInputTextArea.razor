@namespace HyperRazor.Components
@inherits HrzValidationInputComponentBase

<textarea @attributes="InputAttributes">@ResolvedFieldContext.Value</textarea>

@code {
    [Parameter]
    public int? Rows { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public string? Autocomplete { get; set; }

    private IReadOnlyDictionary<string, object> InputAttributes => BuildControlAttributes(new Dictionary<string, object?>
    {
        ["rows"] = Rows?.ToString(),
        ["placeholder"] = Placeholder,
        ["autocomplete"] = Autocomplete
    });
}
