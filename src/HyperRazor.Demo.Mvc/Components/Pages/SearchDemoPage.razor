@* Exercises an HTMX GET form with dynamic query/sort and server-driven pagination. *@
<section class="panel">
    <h2>Live Search</h2>
    <p>Demonstrates HTMX query, sort, and pagination against a fragment endpoint.</p>
</section>

<section id="live-search-demo" class="panel">
    <h3>Live User Search</h3>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> type in Query, change Sort, then use pager buttons.
        Watch inspector headers and query string update on every request.
    </div>
    <p class="demo-caption">
        Expected outcome: list/table/pager swap in place with no full page refresh.
    </p>

    @* One HTMX form handles submit + debounced keyup + select change triggers. *@
    <form
        id="search-controls"
        action="/fragments/users/search"
        hx-get="/fragments/users/search"
        hx-target="#search-results"
        hx-swap="innerHTML"
        hx-indicator="#search-indicator"
        hx-disabled-elt="find button"
        hx-trigger="submit, keyup changed delay:250ms from:#search-box, change from:#sort-select">
        <label for="search-box">Query</label>
        <input
            id="search-box"
            type="search"
            name="query"
            placeholder="Type to search..."
            autocomplete="off" />

        <label for="sort-select">Sort</label>
        <select id="sort-select" name="sort">
            <option value="name-asc" selected>Name (A-Z)</option>
            <option value="name-desc">Name (Z-A)</option>
            <option value="username-asc">Username (A-Z)</option>
            <option value="username-desc">Username (Z-A)</option>
        </select>

        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="pageSize" value="4" />
        <button type="submit">Run Query</button>
        <span id="search-indicator" class="hrz-indicator" aria-live="polite">Searching…</span>
    </form>

    @* Fragment target that receives table + pager markup from server. *@
    <div id="search-results">
        <p>Start typing or change sort to load users.</p>
    </div>
</section>
