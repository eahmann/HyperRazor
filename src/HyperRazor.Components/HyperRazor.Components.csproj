<Project Sdk="Microsoft.NET.Sdk.Razor">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <PackageId>HyperRazor.Components</PackageId>
    <Description>Supported advanced composition package for HyperRazor Razor components, layouts, validation authoring/contracts, and client assets.</Description>
    <StaticWebAssetBasePath>_content/HyperRazor.Components</StaticWebAssetBasePath>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="..\HyperRazor.Htmx\HyperRazor.Htmx.csproj" />
  </ItemGroup>

</Project>
