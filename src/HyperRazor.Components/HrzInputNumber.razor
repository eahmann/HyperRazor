@inherits HrzInputComponentBase

<input @attributes="InputAttributes" />

@code {
    [Parameter]
    public string? Min { get; set; }

    [Parameter]
    public string? Max { get; set; }

    [Parameter]
    public string? Step { get; set; }

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public string? InputMode { get; set; }

    private IReadOnlyDictionary<string, object> InputAttributes => BuildControlAttributes(new Dictionary<string, object?>
    {
        ["type"] = "number",
        ["value"] = ResolvedFieldContext.Value ?? string.Empty,
        ["min"] = Min,
        ["max"] = Max,
        ["step"] = Step,
        ["placeholder"] = Placeholder,
        ["inputmode"] = InputMode
    });
}
