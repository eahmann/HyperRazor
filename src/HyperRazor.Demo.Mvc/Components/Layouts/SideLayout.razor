@inherits LayoutComponentBase

<section id="side-nav-layout-shell" class="panel side-layout-shell">
    <div class="side-layout-grid">
        <aside
            class="side-layout-nav"
            hx-boost="true"
            hx-target="#hrx-main-layout"
            hx-swap="innerHTML show:window:top"
            hx-push-url="true">
            <p class="app-kicker">Alternate Layout</p>
            <h3>Side Navigation</h3>
            <p class="demo-caption">
                These links are hosted by a page-level layout (not the app shell header).
            </p>
            <a href="/demos/layout-swap">Layout Intro</a>
            <a href="/demos/layout-swap/details">Layout Details</a>
            <a href="/demos/basic">Back To Top Nav Layout</a>
        </aside>

        <section class="side-layout-content">
            @Body
        </section>
    </div>
</section>
