@using HyperRazor.Components.Layouts
@using Microsoft.AspNetCore.Components.Rendering
@using Microsoft.AspNetCore.Http
@using Microsoft.AspNetCore.Mvc.ModelBinding

<CascadingValue Value="ShellContext" IsFixed="true">
    <CascadingValue Value="HttpContext" IsFixed="true">
        <CascadingValue Value="ModelState" IsFixed="true">
            @if (IsPartial)
            {
                @_componentContent
                @if (ShouldRenderHeadContent)
                {
                    <HrzHeadContent />
                }
                @if (ShouldRenderSwapContent)
                {
                    <HrzSwapContent />
                }
            }
            else
            {
                <DynamicComponent Type="_resolvedRootComponentType" Parameters="_rootParameters" />
                @if (ShouldRenderHeadContent)
                {
                    <HrzHeadContent />
                }
                @if (ShouldRenderSwapContent)
                {
                    <HrzSwapContent />
                }
            }
        </CascadingValue>
    </CascadingValue>
</CascadingValue>

@code {
    [Parameter, EditorRequired]
    public Type ComponentType { get; set; } = default!;

    [Parameter]
    public IReadOnlyDictionary<string, object?>? ComponentParameters { get; set; }

    [Parameter]
    public bool IsPartial { get; set; }

    [Parameter]
    public Type? RootComponentType { get; set; }

    [Parameter]
    public bool IsHtmxRequest { get; set; }

    [Parameter]
    public bool IsHistoryRestoreRequest { get; set; }

    [Parameter]
    public bool UseMinimalLayoutForHtmx { get; set; } = true;

    [Parameter]
    public HttpContext? HttpContext { get; set; }

    [Parameter]
    public ModelStateDictionary? ModelState { get; set; }

    [Parameter]
    public HrzShellContext? ShellContext { get; set; }

    [Parameter]
    public bool? RenderHeadContent { get; set; }

    [Parameter]
    public bool? RenderSwapContent { get; set; }

    private Type _resolvedRootComponentType = typeof(HrzApp<HrzAppLayout>);
    private Dictionary<string, object?> _rootParameters = new();
    private RenderFragment _componentContent = _ => { };
    private bool ShouldRenderHeadContent => RenderHeadContent ?? (IsHtmxRequest && !IsHistoryRestoreRequest);
    private bool ShouldRenderSwapContent => RenderSwapContent ?? (IsHtmxRequest && !IsHistoryRestoreRequest);

    protected override void OnParametersSet()
    {
        _resolvedRootComponentType = RootComponentType ?? typeof(HrzApp<HrzAppLayout>);
        _componentContent = BuildComponentTree();

        _rootParameters = new Dictionary<string, object?>
        {
            ["Body"] = _componentContent,
            ["IsHtmxRequest"] = IsHtmxRequest,
            ["UseMinimalLayoutForHtmx"] = UseMinimalLayoutForHtmx
        };
    }

    private RenderFragment BuildComponentTree()
    {
        return builder =>
        {
            RenderComponentWithOptionalLayout(builder, ComponentType, ComponentParameters);
        };
    }

    private static void RenderComponentWithOptionalLayout(
        RenderTreeBuilder builder,
        Type componentType,
        IReadOnlyDictionary<string, object?>? parameters)
    {
        var layoutAttribute = (LayoutAttribute?)Attribute.GetCustomAttribute(
            componentType,
            typeof(LayoutAttribute),
            inherit: true);
        var layoutType = layoutAttribute?.LayoutType;

        if (layoutType is null)
        {
            RenderComponent(builder, componentType, parameters);
            return;
        }

        builder.OpenComponent<LayoutView>(0);
        builder.AddAttribute(1, nameof(LayoutView.Layout), layoutType);
        builder.AddAttribute(2, nameof(LayoutView.ChildContent), (RenderFragment)(childBuilder =>
        {
            RenderComponent(childBuilder, componentType, parameters);
        }));
        builder.CloseComponent();
    }

    private static void RenderComponent(
        RenderTreeBuilder builder,
        Type componentType,
        IReadOnlyDictionary<string, object?>? parameters)
    {
        builder.OpenComponent(0, componentType);

        if (parameters is not null)
        {
            var sequence = 1;
            foreach (var parameter in parameters)
            {
                builder.AddAttribute(sequence++, parameter.Key, parameter.Value);
            }
        }

        builder.CloseComponent();
    }
}
