@using HyperRazor.Demo.Mvc.Models
@using HyperRazor.Rendering
@using Microsoft.AspNetCore.Http
@inject IHrzLiveValidationPolicyResolver LiveValidationPolicyResolver

<section
    id="@FormShellId"
    class="panel validation-form-shell"
    data-hrz-validation-root="@Form.RootId.Value"
    data-hrz-validation-region>
    <h3>@Form.PanelTitle</h3>
    <p class="empty">@Form.PanelDescription</p>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> @Form.Instructions
    </div>

    @if (Form.Success)
    {
        <p class="validation-success">
            @Form.SuccessVerb <strong>@Form.Input.DisplayName</strong> (<code>@Form.Input.Email</code>) as user #@Form.Count.
        </p>
    }

    <ValidationServerSummarySlot
        Id="@SummaryId"
        Errors="@(ValidationState?.SummaryErrors ?? Array.Empty<string>())" />

    @{
        var displayNameField = DisplayNameField;
        var emailField = EmailField;
    }

    <form
        id="@FormId"
        class="validation-form"
        action="@Form.Action"
        hx-post="@ResolvedHxPost"
        hx-target="@($"#{FormShellId}")"
        hx-swap="outerHTML focus-scroll:true"
        hx-disabled-elt="find button"
        novalidate>
        <HrzAntiforgeryInput />

        <div class="validation-field @(displayNameField.HasErrors ? "validation-field--invalid" : null)">
            <label for="@displayNameField.InputId">Display Name</label>
            <input
                id="@displayNameField.InputId"
                name="@displayNameField.Name"
                value="@displayNameField.Value"
                aria-invalid="@displayNameField.HasErrors"
                aria-describedby="@displayNameField.AriaDescribedBy"
                data-hrz-field-path="@displayNameField.FieldPath.Value"
                data-hrz-live-policy-id="@(HasLiveValidation ? displayNameField.LivePolicyId : null)"
                data-hrz-local-validation="@(EnableClientValidation ? "min-length" : null)"
                data-hrz-local-min-length="@(EnableClientValidation ? "3" : null)"
                data-hrz-local-min-length-message="@(EnableClientValidation ? "Display name must be at least 3 characters." : null)"
                data-hrz-client-slot-id="@(EnableClientValidation ? displayNameField.ClientSlotId : null)"
                data-hrz-server-slot-id="@(HasLiveValidation ? displayNameField.ServerSlotId : null)"
                data-hrz-summary-slot-id="@(HasLiveValidation ? SummaryId : null)"
                hx-disinherit="@(HasLiveValidation ? "hx-disabled-elt" : null)"
                hx-post="@DisplayNameLiveValidationPath"
                hx-trigger="@LiveValidationTrigger"
                hx-target="@(HasLiveValidation ? $"#{displayNameField.ServerSlotId}" : null)"
                hx-swap="@LiveValidationSwap"
                hx-include="@LiveValidationInclude"
                hx-vals="@displayNameField.LiveValidationValuesJson" />
            <div
                id="@displayNameField.ClientSlotId"
                class="validation-slot validation-slot--client"
                data-hrz-client-validation-for="@displayNameField.FieldPath.Value"></div>
            <ValidationServerFieldSlot
                Id="@displayNameField.ServerSlotId"
                FieldPath="@displayNameField.FieldPath.Value"
                Errors="@displayNameField.Errors" />
        </div>

        <div class="validation-field @(emailField.HasErrors ? "validation-field--invalid" : null)">
            <label for="@emailField.InputId">Email</label>
            <input
                id="@emailField.InputId"
                name="@emailField.Name"
                type="email"
                value="@emailField.Value"
                aria-invalid="@emailField.HasErrors"
                aria-describedby="@emailField.AriaDescribedBy"
                data-hrz-field-path="@emailField.FieldPath.Value"
                data-hrz-live-policy-id="@(HasLiveValidation ? emailField.LivePolicyId : null)"
                data-hrz-local-validation="@(EnableClientValidation ? "email" : null)"
                data-hrz-client-slot-id="@(EnableClientValidation ? emailField.ClientSlotId : null)"
                data-hrz-server-slot-id="@(HasLiveValidation ? emailField.ServerSlotId : null)"
                data-hrz-summary-slot-id="@(HasLiveValidation ? SummaryId : null)"
                data-hrz-dependent-server-slot-ids="@(HasLiveValidation ? displayNameField.ServerSlotId : null)"
                hx-disinherit="@(HasLiveValidation ? "hx-disabled-elt" : null)"
                hx-post="@EmailLiveValidationPath"
                hx-trigger="@LiveValidationTrigger"
                hx-target="@(HasLiveValidation ? $"#{emailField.ServerSlotId}" : null)"
                hx-swap="@LiveValidationSwap"
                hx-include="@LiveValidationInclude"
                hx-vals="@emailField.LiveValidationValuesJson" />
            <div
                id="@emailField.ClientSlotId"
                class="validation-slot validation-slot--client"
                data-hrz-client-validation-for="@emailField.FieldPath.Value"></div>
            <ValidationServerFieldSlot
                Id="@emailField.ServerSlotId"
                FieldPath="@emailField.FieldPath.Value"
                Errors="@emailField.Errors" />
        </div>

        <button type="submit">@Form.ButtonText</button>
    </form>

    @if (HasLiveValidation && DisplayNameLivePolicy is not null && EmailLivePolicy is not null)
    {
        <div id="@LivePolicyRegionId" hidden data-hrz-live-policy-region>
            <ValidationLivePolicyCarrier
                Id="@DisplayNameLivePolicyId"
                Policy="@DisplayNameLivePolicy"
                SummarySlotId="@SummaryId" />
            <ValidationLivePolicyCarrier
                Id="@EmailLivePolicyId"
                Policy="@EmailLivePolicy"
                SummarySlotId="@SummaryId" />
        </div>
    }
</section>

@code {
    public static HrzValidationRootId RootId { get; } = UserInviteValidationRoots.MvcLocal;
    public static HrzFieldPath DisplayNamePath { get; } = HrzFieldPaths.FromFieldName(nameof(InviteUserInput.DisplayName));
    public static HrzFieldPath EmailPath { get; } = HrzFieldPaths.FromFieldName(nameof(InviteUserInput.Email));

    [Parameter]
    public InviteValidationFormViewModel Form { get; set; } = UserInviteValidationDefinitions.MvcLocal();

    [CascadingParameter]
    public HttpContext? HttpContext { get; set; }

    private static readonly IReadOnlyDictionary<HrzFieldPath, HrzAttemptedValue> EmptyAttemptedValues =
        new Dictionary<HrzFieldPath, HrzAttemptedValue>();

    private HrzLiveValidationPolicy? DisplayNameLivePolicy { get; set; }
    private HrzLiveValidationPolicy? EmailLivePolicy { get; set; }

    private HrzSubmitValidationState? ValidationState =>
        HttpContext?.GetSubmitValidationState(Form.RootId);

    private InviteUserInput Input => Form.Input;

    private HrzTextFieldBinding DisplayNameField =>
        HrzTextFieldBinding.Create(
            () => Input.DisplayName,
            ValidationState,
            Form.IdPrefix,
            HasLiveValidation ? Form.RootId : null);

    private HrzTextFieldBinding EmailField =>
        HrzTextFieldBinding.Create(
            () => Input.Email,
            ValidationState,
            Form.IdPrefix,
            HasLiveValidation ? Form.RootId : null);

    private string ResolvedHxPost => string.IsNullOrWhiteSpace(Form.HxPost) ? Form.Action : Form.HxPost;
    private bool EnableClientValidation => Form.EnableClientValidation;
    private bool HasLiveValidation => !string.IsNullOrWhiteSpace(Form.LiveValidationPath);
    private string? DisplayNameLiveValidationPath => HasLiveValidation ? Form.LiveValidationPath : null;
    private string? EmailLiveValidationPath => HasLiveValidation ? Form.LiveValidationPath : null;
    private string? LiveValidationTrigger => HasLiveValidation ? "input changed delay:400ms, blur" : null;
    private string? LiveValidationSwap => HasLiveValidation ? "outerHTML" : null;
    private string? LiveValidationInclude => HasLiveValidation ? "closest form" : null;
    private string FormShellId => GetFormShellId(Form.IdPrefix);
    private string FormId => GetFormId(Form.IdPrefix);
    private string LivePolicyRegionId => GetLivePolicyRegionId(Form.IdPrefix);
    private string SummaryId => GetSummaryId(Form.IdPrefix);
    private string DisplayNameLivePolicyId => GetDisplayNameLivePolicyId(Form.IdPrefix);
    private string EmailLivePolicyId => GetEmailLivePolicyId(Form.IdPrefix);

    protected override async Task OnParametersSetAsync()
    {
        if (!HasLiveValidation)
        {
            DisplayNameLivePolicy = null;
            EmailLivePolicy = null;
            return;
        }

        var attemptedValues = ValidationState?.AttemptedValues ?? EmptyAttemptedValues;

        DisplayNameLivePolicy = await LiveValidationPolicyResolver.ResolveAsync(
            Form.Input,
            Form.RootId,
            DisplayNamePath,
            attemptedValues);

        EmailLivePolicy = await LiveValidationPolicyResolver.ResolveAsync(
            Form.Input,
            Form.RootId,
            EmailPath,
            attemptedValues);
    }

    public static string GetFormShellId(string idPrefix) => $"{idPrefix}-form-shell";

    public static string GetFormId(string idPrefix) => $"{idPrefix}-form";

    public static string GetLivePolicyRegionId(string idPrefix) => $"{idPrefix}-live-policies";

    public static string GetSummaryId(string idPrefix) => $"{idPrefix}-server-summary";

    public static string GetDisplayNameServerId(string idPrefix) => $"{idPrefix}-display-name-server";

    public static string GetDisplayNameLivePolicyId(string idPrefix) => $"{idPrefix}-display-name-live";

    public static string GetEmailServerId(string idPrefix) => $"{idPrefix}-email-server";

    public static string GetEmailLivePolicyId(string idPrefix) => $"{idPrefix}-email-live";
}
