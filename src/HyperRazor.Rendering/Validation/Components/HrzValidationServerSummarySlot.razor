@namespace HyperRazor.Components

<div
    id="@Id"
    class="@SummaryClass"
    data-hrz-server-validation-summary
    hx-swap-oob="@(SwapOob ? "outerHTML" : null)"
    @attributes="AdditionalAttributes">
    @if (Errors.Count > 0)
    {
        <ul class="validation-errors">
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public string Id { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<string> Errors { get; set; } = Array.Empty<string>();

    [Parameter]
    public bool SwapOob { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    private string SummaryClass => string.Join(
        " ",
        new[]
        {
            Errors.Count == 0
                ? "validation-summary validation-summary--empty"
                : "validation-summary",
            Class
        }.Where(static value => !string.IsNullOrWhiteSpace(value)));
}
