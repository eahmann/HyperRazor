@* Demonstrates status-code responses with HTMX 2 responseHandling policy in place. *@
<section class="panel">
    <h2>Status Handling</h2>
    <p>Exercises <code>401</code>, <code>403</code>, <code>404</code>, and <code>500</code> fragment responses.</p>
</section>

<section id="status-demo" class="panel">
    <h3>Status + Error Responses</h3>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> click each button and compare the status code in the inspector.
        These swaps stay in-place because HTMX response handling is configured for <code>4xx/5xx</code>.
    </div>
    <p class="demo-caption">
        Expected outcome: the result panel updates for each status, and <code>500</code> also pushes an OOB toast.
    </p>

    <div class="status-actions">
        <button type="button" hx-get="/fragments/errors/401" hx-target="#status-result" hx-swap="outerHTML" hx-indicator="#status-indicator" hx-disabled-elt="this">Simulate 401</button>
        <button type="button" hx-get="/fragments/errors/403" hx-target="#status-result" hx-swap="outerHTML" hx-indicator="#status-indicator" hx-disabled-elt="this">Simulate 403</button>
        <button type="button" hx-get="/fragments/errors/404" hx-target="#status-result" hx-swap="outerHTML" hx-indicator="#status-indicator" hx-disabled-elt="this">Simulate 404</button>
        <button type="button" hx-get="/fragments/errors/500" hx-target="#status-result" hx-swap="outerHTML" hx-indicator="#status-indicator" hx-disabled-elt="this">Simulate 500</button>
        <span id="status-indicator" class="hrx-indicator" aria-live="polite">Loading status demo…</span>
    </div>

    <section id="status-result" class="panel status-result">
        <h3>Ready</h3>
        <p>Click a status button to load a server-generated response fragment.</p>
    </section>

    <div id="toast-stack" class="toast-stack"></div>
</section>
