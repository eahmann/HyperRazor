@using Microsoft.AspNetCore.Components.Forms

<HrzValidationServerSummarySlot
    Id="@ResolvedFormScope.SummaryId"
    Errors="@(ResolvedFormScope.ValidationState?.SummaryErrors ?? Array.Empty<string>())"
    Class="@Class"
    AdditionalAttributes="@AdditionalAttributes" />

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HrzFormScope? FormScope { get; set; }

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    private HrzFormScope ResolvedFormScope => FormScope
        ?? ResolveFormScopeFromEditContext()
        ?? throw new InvalidOperationException(
            $"{nameof(HrzValidationSummary)} requires a cascading {nameof(HrzForm<object>)} or an {nameof(EditForm)} validation bridge.");

    protected override void OnParametersSet()
    {
        _ = ResolvedFormScope;
    }

    private HrzFormScope? ResolveFormScopeFromEditContext()
    {
        return HrzEditFormState.TryGetFormScope(EditContext, out var formScope)
            ? formScope
            : null;
    }
}
