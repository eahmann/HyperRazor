@namespace HyperRazor.Components

<select
    id="@ResolvedFieldContext.InputId"
    name="@ResolvedFieldContext.Name"
    class="@Class"
    multiple="@Multiple"
    aria-invalid="@ResolvedFieldContext.HasErrors"
    aria-describedby="@ResolvedFieldContext.AriaDescribedBy"
    data-hrz-field-path="@ResolvedFieldContext.FieldPath.Value"
    data-hrz-live-policy-id="@(ResolvedFieldContext.HasLiveValidation ? ResolvedFieldContext.LivePolicyId : null)"
    data-hrz-local-validation="@ResolvedFieldContext.LocalValidationRule"
    data-hrz-local-min-length="@(ResolvedFieldContext.LocalMinLength?.ToString())"
    data-hrz-local-min-length-message="@ResolvedFieldContext.LocalMinLengthMessage"
    data-hrz-client-slot-id="@(ResolvedFieldContext.EnableClientValidation ? ResolvedFieldContext.ClientSlotId : null)"
    data-hrz-server-slot-id="@(ResolvedFieldContext.HasLiveValidation ? ResolvedFieldContext.ServerSlotId : null)"
    data-hrz-summary-slot-id="@(ResolvedFieldContext.HasLiveValidation ? ResolvedFieldContext.Form.SummaryId : null)"
    hx-disinherit="@(ResolvedFieldContext.HasLiveValidation ? "hx-disabled-elt" : null)"
    hx-post="@ResolvedFieldContext.LiveValidationPath"
    hx-trigger="@ResolvedFieldContext.LiveTrigger"
    hx-target="@(ResolvedFieldContext.HasLiveValidation ? $"#{ResolvedFieldContext.ServerSlotId}" : null)"
    hx-swap="@(ResolvedFieldContext.HasLiveValidation ? "outerHTML" : null)"
    hx-include="@ResolvedFieldContext.LiveInclude"
    hx-sync="@ResolvedFieldContext.LiveSync"
    hx-vals="@ResolvedFieldContext.LiveValidationValuesJson"
    @attributes="AdditionalAttributes">
    @if (!string.IsNullOrWhiteSpace(Placeholder))
    {
        <option value="" selected="@(!Multiple && ResolvedFieldContext.Values.Count == 0)">@Placeholder</option>
    }

    @foreach (var option in Options)
    {
        <option
            value="@option.Value"
            selected="@IsSelected(option.Value)"
            disabled="@option.Disabled">@option.Label</option>
    }
</select>

@code {
    [Parameter]
    public IReadOnlyList<HrzSelectOption> Options { get; set; } = Array.Empty<HrzSelectOption>();

    [Parameter]
    public string? Placeholder { get; set; }

    [Parameter]
    public bool Multiple { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HrzValidationFieldContext? FieldContext { get; set; }

    private HrzValidationFieldContext ResolvedFieldContext => FieldContext
        ?? throw new InvalidOperationException($"{nameof(HrzSelect)} requires a cascading {nameof(HrzField<object>)}.");

    private bool IsSelected(string value)
    {
        return ResolvedFieldContext.Values.Contains(value, StringComparer.Ordinal);
    }

    protected override void OnParametersSet()
    {
        _ = ResolvedFieldContext;
    }
}
