@inherits HrzInputComponentBase

<input checked="@ResolvedField.IsChecked" @attributes="InputAttributes" />

@if (IncludeHiddenInput)
{
    <input type="hidden" name="@ResolvedField.Name" value="false" disabled="@IsDisabled" />
}

@code {
    [Parameter]
    public bool IncludeHiddenInput { get; set; } = true;

    private IReadOnlyDictionary<string, object> InputAttributes => BuildControlAttributes(new Dictionary<string, object?>
    {
        ["type"] = "checkbox",
        ["value"] = "true"
    });

    private bool IsDisabled => InputAttributes.ContainsKey("disabled");
}
