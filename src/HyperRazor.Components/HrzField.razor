@typeparam TValue
@using System.Linq.Expressions
@using Microsoft.AspNetCore.Components.Forms

<div class="@FieldClass">
    <CascadingValue Value="_fieldScope">
        @ChildContent
    </CascadingValue>
</div>

@implements IDisposable

@code {
    [Parameter, EditorRequired]
    public Expression<Func<TValue>> For { get; set; } = default!;

    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public bool? EnableClientValidation { get; set; }

    [Parameter]
    public bool? Live { get; set; }

    [Parameter]
    public HrzFieldLiveOptions? LiveOptions { get; set; }

    [Parameter]
    public string? LiveValidationPath { get; set; }

    [Parameter]
    public string? LiveTrigger { get; set; }

    [Parameter]
    public string? LiveInclude { get; set; }

    [Parameter]
    public string? LiveSync { get; set; }

    [Parameter]
    public string? Class { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [CascadingParameter]
    private HrzFormScope? FormScope { get; set; }

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    private static readonly object EditFormScopeKey = typeof(HrzFormScope);
    private HrzFieldScope<TValue> _fieldScope = default!;
    private HrzFieldPath? _registeredFieldPath;
    private Expression<Func<TValue>>? _cachedFor;
    private Func<TValue>? _compiledAccessor;

    private string FieldClass => string.Join(
        " ",
        new[]
        {
            "validation-field",
            _fieldScope.HasErrors ? "validation-field--invalid" : null,
            Class
        }.Where(static value => !string.IsNullOrWhiteSpace(value)));

    protected override void OnParametersSet()
    {
        var resolvedFormScope = FormScope ?? ResolveFormScopeFromEditContext();
        if (resolvedFormScope is null)
        {
            throw new InvalidOperationException(
                $"{nameof(HrzField<object>)} requires a cascading {nameof(HrzForm<object>)} or an {nameof(EditForm)} validation bridge.");
        }

        var compiledAccessor = _compiledAccessor;
        if (!ReferenceEquals(For, _cachedFor) || compiledAccessor is null)
        {
            compiledAccessor = For.Compile();
            _compiledAccessor = compiledAccessor;
            _cachedFor = For;
        }

        _fieldScope = resolvedFormScope.Field(
            For,
            compiledAccessor,
            Label,
            EnableClientValidation,
            ResolveLiveOptions());

        if (_registeredFieldPath is not null && !_registeredFieldPath.Equals(_fieldScope.FieldPath))
        {
            resolvedFormScope.UnregisterField(_registeredFieldPath);
        }

        if (_fieldScope.HasLiveValidation)
        {
            _registeredFieldPath = _fieldScope.FieldPath;
        }
        else if (_registeredFieldPath is not null)
        {
            resolvedFormScope.UnregisterField(_registeredFieldPath);
            _registeredFieldPath = null;
        }
    }

    public void Dispose()
    {
        var resolvedFormScope = FormScope ?? ResolveFormScopeFromEditContext();
        if (resolvedFormScope is not null && _registeredFieldPath is not null)
        {
            resolvedFormScope.UnregisterField(_registeredFieldPath);
            _registeredFieldPath = null;
        }
    }

    private HrzFormScope? ResolveFormScopeFromEditContext()
    {
        return EditContext is not null
            && EditContext.Properties.TryGetValue(EditFormScopeKey, out var value)
            && value is HrzFormScope formScope
                ? formScope
                : null;
    }

    private HrzFieldLiveOptions? ResolveLiveOptions()
    {
        if (LiveOptions is null
            && Live is null
            && LiveValidationPath is null
            && LiveTrigger is null
            && LiveInclude is null
            && LiveSync is null)
        {
            return null;
        }

        return new HrzFieldLiveOptions
        {
            Enabled = Live ?? LiveOptions?.Enabled,
            Path = LiveValidationPath ?? LiveOptions?.Path,
            Trigger = LiveTrigger ?? LiveOptions?.Trigger,
            Include = LiveInclude ?? LiveOptions?.Include,
            Sync = LiveSync ?? LiveOptions?.Sync
        };
    }
}
