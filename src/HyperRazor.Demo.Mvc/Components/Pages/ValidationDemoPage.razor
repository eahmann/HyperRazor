@* Server-side validation demo intentionally returns 200 for invalid submissions. *@
<section class="panel">
    <h2>Form Validation</h2>
    <p>Demonstrates server-side validation with inline fragment errors while keeping invalid submits at <code>200 OK</code>.</p>
</section>

<section id="validation-demo" class="panel">
    <h3>Create User (Validated)</h3>
    <p class="empty">Try invalid input first, then submit valid input.</p>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> submit `A` + `invalid` first, then a proper name/email.
        The response swaps only the result area and keeps the form in place.
    </div>
    <p class="demo-caption">
        Expected outcome: errors and success both render in <code>#validation-result</code> without navigation.
    </p>

    @* HTMX target is scoped to #validation-result so only result state changes per submit. *@
    <form
        id="validation-form"
        action="/fragments/users/create-validated"
        hx-post="/fragments/users/create-validated"
        hx-target="#validation-result"
        hx-swap="innerHTML focus-scroll:true"
        hx-indicator="#validation-indicator"
        hx-disabled-elt="find button"
        novalidate>
        <HrxAntiforgeryInput />

        <label for="validation-display-name">Display Name</label>
        <input id="validation-display-name" name="displayName" value="Riley Stone" />

        <label for="validation-email">Email</label>
        <input id="validation-email" name="email" type="email" value="riley@example.com" />

        <button type="submit">Submit</button>
        <span id="validation-indicator" class="hrx-indicator" aria-live="polite">Validating…</span>
    </form>

    @* Partial fragment mount point for success/error state. *@
    <div id="validation-result">
        <p class="empty">Awaiting submission.</p>
    </div>
</section>
