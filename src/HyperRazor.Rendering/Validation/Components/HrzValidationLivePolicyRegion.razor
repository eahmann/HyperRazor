@namespace HyperRazor.Components
@using HyperRazor.Rendering
@inject IHrzLiveValidationPolicyResolver LiveValidationPolicyResolver

@if (Policies.Count > 0)
{
    <div id="@ResolvedFormContext.LivePolicyRegionId" hidden data-hrz-live-policy-region>
        @foreach (var field in ResolvedFormContext.RegisteredLiveFields)
        {
            if (Policies.TryGetValue(field.FieldPath, out var policy))
            {
                <HrzValidationLivePolicyCarrier
                    Id="@field.LivePolicyId"
                    Policy="@policy"
                    SummarySlotId="@ResolvedFormContext.SummaryId" />
            }
        }
    </div>
}

@code {
    [CascadingParameter]
    private HrzValidationFormContext? FormContext { get; set; }

    private HrzValidationFormContext ResolvedFormContext => FormContext
        ?? throw new InvalidOperationException($"{nameof(HrzValidationLivePolicyRegion)} requires a cascading {nameof(HrzForm<object>)}.");

    private static readonly IReadOnlyDictionary<HrzFieldPath, HrzAttemptedValue> EmptyAttemptedValues =
        new Dictionary<HrzFieldPath, HrzAttemptedValue>();

    private IReadOnlyDictionary<HrzFieldPath, HrzLiveValidationPolicy> Policies { get; set; } =
        new Dictionary<HrzFieldPath, HrzLiveValidationPolicy>();

    protected override async Task OnParametersSetAsync()
    {
        _ = ResolvedFormContext;

        if (ResolvedFormContext.RegisteredLiveFields.Count == 0)
        {
            Policies = new Dictionary<HrzFieldPath, HrzLiveValidationPolicy>();
            return;
        }

        var attemptedValues = ResolvedFormContext.ValidationState?.AttemptedValues ?? EmptyAttemptedValues;
        var policies = new Dictionary<HrzFieldPath, HrzLiveValidationPolicy>();

        foreach (var field in ResolvedFormContext.RegisteredLiveFields)
        {
            policies[field.FieldPath] = await LiveValidationPolicyResolver.ResolveAsync(
                ResolvedFormContext.Model,
                ResolvedFormContext.RootId,
                field.FieldPath,
                attemptedValues);
        }

        Policies = policies;
    }
}
