@implements IDisposable
@inject HrzSwapService SwapService

@if (SwapService.HasBufferedContent)
{
    @SwapService.RenderBufferedFragment(clear: true)
}

@code {
    protected override void OnInitialized()
    {
        SwapService.BufferedContentChanged += OnContentItemsUpdated;
    }

    public void Dispose()
    {
        SwapService.BufferedContentChanged -= OnContentItemsUpdated;
    }

    private void OnContentItemsUpdated(object? sender, EventArgs args)
    {
        _ = InvokeAsync(StateHasChanged);
    }
}
