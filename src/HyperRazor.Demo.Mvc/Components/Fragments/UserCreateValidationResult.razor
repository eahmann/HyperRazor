<section id="validated-user-result" class="panel">
    <p class="demo-caption">
        Result panel note: this region is the only target swapped by the validation form.
    </p>
    @if (Success)
    {
        @* Success state replaces previous errors in same fragment mount point. *@
        <h3>Validation Passed</h3>
        <p class="validation-success">
            Created <strong>@DisplayName</strong> (<code>@Email</code>) as user #@Count.
        </p>
    }
    else
    {
        @* Error state keeps per-field messages in a single response region. *@
        <h3>Validation Errors</h3>
        <ul class="validation-errors">
            @foreach (var error in Errors)
            {
                <li>@error</li>
            }
        </ul>
    }
</section>

@code {
    [Parameter]
    public bool Success { get; set; }

    [Parameter]
    public string DisplayName { get; set; } = string.Empty;

    [Parameter]
    public string Email { get; set; } = string.Empty;

    [Parameter]
    public IReadOnlyList<string> Errors { get; set; } = Array.Empty<string>();

    [Parameter]
    public int Count { get; set; }
}
