@typeparam TLayout where TLayout : IComponent

@if (IsHtmxRequest)
{
    if (UseMinimalLayoutForHtmx)
    {
        <HrzMinimalLayout>
            @ChildContent
        </HrzMinimalLayout>
    }
    else
    {
        <HrzEmptyLayout>
            @ChildContent
        </HrzEmptyLayout>
    }
}
else
{
    <LayoutView Layout="typeof(TLayout)">
        @ChildContent
    </LayoutView>
}

@code {
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public bool IsHtmxRequest { get; set; }

    [Parameter]
    public bool UseMinimalLayoutForHtmx { get; set; } = true;
}
