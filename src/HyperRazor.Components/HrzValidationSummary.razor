@using Microsoft.AspNetCore.Components.Forms

<HrzValidationServerSummarySlot
    Id="@ResolvedFormContext.SummaryId"
    Errors="@(ResolvedFormContext.ValidationState?.SummaryErrors ?? Array.Empty<string>())"
    Class="@Class"
    AdditionalAttributes="@AdditionalAttributes" />

@code {
    [Parameter]
    public string? Class { get; set; }

    [Parameter(CaptureUnmatchedValues = true)]
    public IReadOnlyDictionary<string, object?>? AdditionalAttributes { get; set; }

    [CascadingParameter]
    private HrzValidationFormContext? FormContext { get; set; }

    [CascadingParameter]
    private EditContext? EditContext { get; set; }

    private HrzValidationFormContext ResolvedFormContext => FormContext
        ?? HrzValidationFormContext.ResolveFrom(EditContext)
        ?? throw new InvalidOperationException(
            $"{nameof(HrzValidationSummary)} requires a cascading {nameof(HrzForm<object>)} or an {nameof(EditForm)} validation bridge.");

    protected override void OnParametersSet()
    {
        _ = ResolvedFormContext;
    }
}
