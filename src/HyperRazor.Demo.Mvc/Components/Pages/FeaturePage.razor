@* OOB demo: one request updates primary target plus several out-of-band regions. *@
<section id="feature-panel" class="panel">
    <h2>OOB Swaps</h2>
    <p>Rendered as SSR component markup with one HTMX action updating multiple regions out-of-band.</p>
</section>

<section class="panel">
    <h3>OOB Demo</h3>
    <p>Single HTMX request updates main content plus multiple OOB regions (count, toast, activity, layout inspector).</p>
    <p>Users: <span id="user-count-shell" class="count-badge">5</span></p>
    <div class="demo-note" role="note">
        <strong>How To Test:</strong> submit either form and watch <code>#users-list</code>, count badge, toast stack,
        activity feed, and inspector update together from one response.
    </div>
    <p class="demo-caption">
        Expected outcome: one request produces multiple DOM updates via OOB payload blocks.
    </p>

    @* Standard flow: main fragment response + OOB queue from HrxSwapContent. *@
    <form
        action="/fragments/users/create"
        hx-post="/fragments/users/create"
        hx-target="#users-list"
        hx-swap="outerHTML focus-scroll:true"
        hx-indicator="#oob-indicator"
        hx-disabled-elt="find button">
        <HrxAntiforgeryInput />

        <label for="displayName">Display Name</label>
        <input id="displayName" name="displayName" value="Taylor Reed" />
        <button type="submit">Create User</button>
    </form>

    @* Alternate flow: controller calls IHrxSwapService.RenderToString(clear: true). *@
    <form
        id="render-to-string-form"
        action="/fragments/users/create-rendered"
        hx-post="/fragments/users/create-rendered"
        hx-target="#render-to-string-demo-result"
        hx-swap="outerHTML focus-scroll:true"
        hx-indicator="#oob-indicator"
        hx-disabled-elt="find button">
        <HrxAntiforgeryInput />

        <label for="displayNameRendered">Display Name (RenderToString path)</label>
        <input id="displayNameRendered" name="displayName" value="Morgan Lake" />
        <button type="submit">Create User via RenderToString</button>
    </form>

    <span id="oob-indicator" class="hrx-indicator" aria-live="polite">Applying updates…</span>

    <section id="users-list" class="panel">
        <h3>Latest Created User</h3>
        <p>No users created in this session.</p>
    </section>

    <section id="render-to-string-demo-result" class="panel">
        <h3>RenderToString Result</h3>
        <p class="empty">Submit "Create User via RenderToString" to exercise the string-rendering OOB path.</p>
    </section>

    @* OOB toast region receives beforeend inserts from server queue. *@
    <div id="toast-stack" class="toast-stack"></div>
</section>

<section class="panel">
    <h3>Activity Feed (OOB)</h3>
    <p class="empty">Each create request appends a new feed item.</p>
    <div id="activity-feed" class="activity-feed"></div>
</section>
