<section id="server-trigger-demo" class="panel">
    <h3>Server Trigger</h3>
    <p class="empty">Compare trigger payload from action code vs `[HtmxResponse]` attribute.</p>

    <button
        type="button"
        hx-get="/fragments/toast/success"
        hx-target="#toast-region"
        hx-swap="innerHTML">
        Trigger Toast (Body Trigger)
    </button>

    <button
        type="button"
        hx-get="/fragments/toast/success-attribute"
        hx-target="#toast-region"
        hx-swap="innerHTML">
        Trigger Toast (Attribute Trigger)
    </button>
    <div id="toast-region"></div>
    <p id="event-log" aria-live="polite">No server events yet.</p>
</section>

<script>
    document.body.addEventListener("toast:show", function (event) {
        var detail = event.detail || {};
        var message = detail.message || "Server event received.";
        var log = document.getElementById("event-log");
        if (log) {
            log.textContent = message;
        }
    });
</script>
